---
interface DifficultyFilter {
  key: string;
  label: string;
  cls: string;
}

interface Props {
  categories: string[];
  categoryCounts: Record<string, number>;
  totalCount: number;
  youthHighlightCount: number;
  seniorCount: number;
  disabledCount: number;
  newImmigrantCount: number;
  indigenousCount: number;
  lowIncomeCount: number;
  singleParentCount: number;
  youngChildCount: number;
  studentCount: number;
  workerCount: number;
  middleAgedCount: number;
  veteranCount: number;
  farmerCount: number;
  recencyCount: number;
  recencyDays: number;
  SENIOR_LABEL: string;
  DISABILITY_LABEL: string;
  NEW_IMMIGRANT_LABEL: string;
  INDIGENOUS_LABEL: string;
  LOW_INCOME_LABEL: string;
  SINGLE_PARENT_LABEL: string;
  YOUNG_CHILD_LABEL: string;
  STUDENT_LABEL: string;
  WORKER_LABEL: string;
  MIDDLE_AGED_LABEL: string;
  VETERAN_LABEL: string;
  FARMER_LABEL: string;
  RECENCY_LABEL: string;
  difficultyFilters: DifficultyFilter[];
  difficultyCounts: Record<string, number>;
  agencies: string[];
  agencyCounts: Record<string, number>;
}

const {
  categories, categoryCounts, totalCount,
  youthHighlightCount, seniorCount, disabledCount, newImmigrantCount, indigenousCount,
  lowIncomeCount, singleParentCount, youngChildCount, studentCount, workerCount,
  middleAgedCount, veteranCount, farmerCount, recencyCount, recencyDays,
  SENIOR_LABEL, DISABILITY_LABEL, NEW_IMMIGRANT_LABEL, INDIGENOUS_LABEL, LOW_INCOME_LABEL,
  SINGLE_PARENT_LABEL, YOUNG_CHILD_LABEL, STUDENT_LABEL, WORKER_LABEL, MIDDLE_AGED_LABEL,
  VETERAN_LABEL, FARMER_LABEL, RECENCY_LABEL,
  difficultyFilters, difficultyCounts, agencies, agencyCounts,
} = Astro.props;

function getCount(cat: string): number {
  if (cat === '全部') return totalCount;
  if (cat === '⭐ 青年必看') return youthHighlightCount;
  if (cat === SENIOR_LABEL) return seniorCount;
  if (cat === DISABILITY_LABEL) return disabledCount;
  if (cat === NEW_IMMIGRANT_LABEL) return newImmigrantCount;
  if (cat === INDIGENOUS_LABEL) return indigenousCount;
  if (cat === LOW_INCOME_LABEL) return lowIncomeCount;
  if (cat === SINGLE_PARENT_LABEL) return singleParentCount;
  if (cat === YOUNG_CHILD_LABEL) return youngChildCount;
  if (cat === STUDENT_LABEL) return studentCount;
  if (cat === WORKER_LABEL) return workerCount;
  if (cat === MIDDLE_AGED_LABEL) return middleAgedCount;
  if (cat === VETERAN_LABEL) return veteranCount;
  if (cat === FARMER_LABEL) return farmerCount;
  if (cat === RECENCY_LABEL) return recencyCount;
  return categoryCounts[cat] || 0;
}

function getCatClass(cat: string): string {
  const classes = ['filter-btn'];
  if (cat === '全部') classes.push('active');
  if (cat === '⭐ 青年必看') classes.push('youth-filter');
  if (cat === SENIOR_LABEL) classes.push('senior-filter');
  if (cat === DISABILITY_LABEL) classes.push('disability-filter');
  if (cat === NEW_IMMIGRANT_LABEL) classes.push('new-immigrant-filter');
  if (cat === INDIGENOUS_LABEL) classes.push('indigenous-filter');
  if (cat === LOW_INCOME_LABEL) classes.push('low-income-filter');
  if (cat === SINGLE_PARENT_LABEL) classes.push('single-parent-filter');
  if (cat === YOUNG_CHILD_LABEL) classes.push('young-child-filter');
  if (cat === STUDENT_LABEL) classes.push('student-filter');
  if (cat === WORKER_LABEL) classes.push('worker-filter');
  if (cat === MIDDLE_AGED_LABEL) classes.push('middle-aged-filter');
  if (cat === VETERAN_LABEL) classes.push('veteran-filter');
  if (cat === FARMER_LABEL) classes.push('farmer-filter');
  if (cat === RECENCY_LABEL) classes.push('recency-filter');
  return classes.join(' ');
}

function getCatId(cat: string): string | undefined {
  if (cat === RECENCY_LABEL) return 'recencyFilterBtn';
  if (cat === SENIOR_LABEL) return 'seniorFilterBtn';
  if (cat === DISABILITY_LABEL) return 'disabilityFilterBtn';
  if (cat === NEW_IMMIGRANT_LABEL) return 'newImmigrantFilterBtn';
  if (cat === INDIGENOUS_LABEL) return 'indigenousFilterBtn';
  if (cat === LOW_INCOME_LABEL) return 'lowIncomeFilterBtn';
  if (cat === SINGLE_PARENT_LABEL) return 'singleParentFilterBtn';
  if (cat === YOUNG_CHILD_LABEL) return 'youngChildFilterBtn';
  if (cat === STUDENT_LABEL) return 'studentFilterBtn';
  if (cat === WORKER_LABEL) return 'workerFilterBtn';
  if (cat === MIDDLE_AGED_LABEL) return 'middleAgedFilterBtn';
  if (cat === VETERAN_LABEL) return 'veteranFilterBtn';
  if (cat === FARMER_LABEL) return 'farmerFilterBtn';
  return undefined;
}
---

<div class="controls">
  <div class="search-box" id="searchBox">
    <span class="search-icon">🔍</span>
    <input
      type="search"
      id="searchInput"
      placeholder="搜尋補助名稱、類別或關鍵字…"
      aria-label="搜尋補助"
      aria-autocomplete="list"
      aria-expanded="false"
      aria-controls="searchSuggestions"
      role="combobox"
      autocomplete="off"
    />
    <ul id="searchSuggestions" class="search-suggestions" role="listbox" aria-label="補助建議清單" hidden></ul>
  </div>
  <div id="fuzzyHint" class="fuzzy-hint" hidden role="status" aria-live="polite" aria-atomic="true"></div>
  <div class="category-filters" role="toolbar" aria-label="類別篩選">
    {categories.map((cat) => {
      const count = getCount(cat);
      const id = getCatId(cat);
      return (
        <button
          class={getCatClass(cat)}
          id={id}
          data-category={cat}
          data-recency-days={cat === RECENCY_LABEL ? recencyDays : undefined}
          type="button"
          aria-pressed={cat === '全部' ? 'true' : 'false'}
          aria-label={`篩選類別：${cat}（${count} 項）`}
          tabindex={cat === '全部' ? '0' : '-1'}
        >
          {cat} <span class="count-badge">{count}</span>
        </button>
      );
    })}
  </div>
  <div class="difficulty-filters" role="group" aria-label="難度篩選">
    {difficultyFilters.map(df => (
      <button class={`filter-btn ${df.cls}`} data-difficulty={df.key} type="button" aria-pressed="false">
        {df.label} <span class="count-badge">{difficultyCounts[df.key]}</span>
      </button>
    ))}
  </div>
  <div class="urgency-filters" role="group" aria-label="截止日期篩選">
    <button class="filter-btn urgency-7-filter" data-urgency="7" type="button" aria-pressed="false">🔴 7天內截止 <span class="count-badge">0</span></button>
    <button class="filter-btn urgency-30-filter" data-urgency="30" type="button" aria-pressed="false">🟡 30天內截止 <span class="count-badge">0</span></button>
    <button class="filter-btn urgency-60-filter" data-urgency="60" type="button" aria-pressed="false">📅 60天內截止 <span class="count-badge">0</span></button>
  </div>
  <div class="county-filter-row">
    <label class="county-filter-label" for="countySelect">📍 縣市篩選</label>
    <select id="countySelect" class="county-select" aria-label="選擇縣市">
      <option value="">全國（顯示所有）</option>
      <optgroup label="北部">
        <option value="台北市">台北市</option>
        <option value="新北市">新北市</option>
        <option value="基隆市">基隆市</option>
        <option value="桃園市">桃園市</option>
        <option value="新竹市">新竹市</option>
        <option value="新竹縣">新竹縣</option>
        <option value="宜蘭縣">宜蘭縣</option>
      </optgroup>
      <optgroup label="中部">
        <option value="台中市">台中市</option>
        <option value="苗栗縣">苗栗縣</option>
        <option value="彰化縣">彰化縣</option>
        <option value="南投縣">南投縣</option>
        <option value="雲林縣">雲林縣</option>
      </optgroup>
      <optgroup label="南部">
        <option value="台南市">台南市</option>
        <option value="高雄市">高雄市</option>
        <option value="嘉義市">嘉義市</option>
        <option value="嘉義縣">嘉義縣</option>
        <option value="屏東縣">屏東縣</option>
      </optgroup>
      <optgroup label="東部">
        <option value="花蓮縣">花蓮縣</option>
        <option value="台東縣">台東縣</option>
      </optgroup>
      <optgroup label="離島">
        <option value="澎湖縣">澎湖縣</option>
        <option value="金門縣">金門縣</option>
        <option value="連江縣">連江縣</option>
      </optgroup>
    </select>
  </div>
  <div class="agency-filter-row" id="agencyFilterRow">
    <button class="agency-toggle-btn" id="agencyToggle" type="button" aria-expanded="true" aria-controls="agencyChips">
      🏛️ 機構
      <span class="agency-toggle-arrow" aria-hidden="true">▼</span>
    </button>
    <div class="agency-chips" id="agencyChips" role="group" aria-label="機構篩選">
      {agencies.map(agency => (
        <button class="agency-chip" data-agency={agency} type="button" aria-pressed="false">
          {agency} <span class="count-badge">{agencyCounts[agency]}</span>
        </button>
      ))}
    </div>
  </div>
  <div class="sort-row">
    <button class="sort-btn" id="sortDifficulty" type="button" aria-pressed="false">依申請難度排序</button>
    <button class="sort-btn" id="sortAmount" type="button" aria-pressed="false">依金額高低</button>
    <button class="sort-btn tracker-filter-btn" id="trackerFilter" type="button" aria-pressed="false">📌 只看追蹤中</button>
    <button class="sort-btn show-closed-btn" id="showClosedBtn" type="button" aria-pressed="false">⏸ 顯示已截止補助</button>
  </div>
</div>

<div class="eligibility-banner" id="eligibilityBanner" style="display:none" role="status" aria-live="polite">
  <span class="banner-emoji">🎯</span>
  <span id="bannerText"></span>
</div>

<div class="eligible-total-banner" id="eligibleTotalBanner" style="display:none" role="status" aria-live="polite">
  <span class="banner-emoji">💰</span>
  <span id="totalBannerText" class="total-banner-text" tabindex="0" title="此金額為各項補助最高上限加總，實際核撥依個人資格而定" aria-label="此金額為各項補助最高上限加總，實際核撥依個人資格而定"></span>
</div>

<div class="tracker-deadline-banner" id="trackerDeadlineBanner" style="display:none" role="status" aria-live="polite">
  <div class="tracker-deadline-banner-header">
    <span>📋 你追蹤中的補助即將截止：</span>
    <button class="tracker-deadline-dismiss" id="trackerDeadlineDismiss" type="button" aria-label="關閉截止提醒">✕ 關閉</button>
  </div>
  <ul class="tracker-deadline-list" id="trackerDeadlineList"></ul>
</div>

<div class="tracker-closed-banner" id="trackerClosedBanner" style="display:none" role="alert" aria-live="polite">
  <div class="tracker-deadline-banner-header">
    <span>⚠️ 你追蹤中的補助已截止申請：</span>
    <button class="tracker-deadline-dismiss" id="trackerClosedDismiss" type="button" aria-label="關閉已截止提醒">✕ 關閉</button>
  </div>
  <ul class="tracker-deadline-list" id="trackerClosedList"></ul>
</div>

<div class="tracker-summary-banner" id="trackerSummaryBanner" style="display:none" role="status" aria-live="polite">
  <span class="tracker-summary-text">📌 已追蹤 <strong><span id="trackerSummaryCount">0</span></strong> 項補助<span id="trackerStatusBreakdown" class="tracker-status-breakdown"></span></span>
  <div class="tracker-summary-actions">
    <button class="ical-export-btn" id="icalExportBtn" type="button" style="display:none" aria-label="匯出追蹤補助截止日期至行事曆">📅 匯出行事曆</button>
    <button class="csv-export-btn" id="csvExportBtn" type="button" style="display:none" aria-label="匯出追蹤補助清單為 CSV">📥 匯出 CSV</button>
    <button class="print-tracker-btn" id="printTrackerBtn" type="button">🖨️ 列印追蹤清單</button>
  </div>
</div>

<section class="deadline-panel" id="deadlinePanelSection" style="display:none" aria-label="即將截止補助">
  <div class="deadline-panel-header">
    <h2 class="deadline-panel-title">📅 即將截止</h2>
    <button class="deadline-panel-toggle" id="deadlinePanelToggle" type="button" aria-expanded="true">隱藏</button>
  </div>
  <div class="deadline-panel-body" id="deadlinePanelBody">
    <ol class="deadline-timeline" id="deadlineTimeline" aria-label="截止日期排行"></ol>
    <button class="deadline-show-all-btn" id="deadlineShowAll" type="button" style="display:none">查看全部</button>
  </div>
</section>

<div class="results-row">
  <p class="results-count" id="resultsCount">共 {totalCount} 項補助</p>
  <button class="print-list-btn" id="printListBtn" type="button" aria-label="列印目前補助清單">🖨️ 列印補助清單</button>
</div>
