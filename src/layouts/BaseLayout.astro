---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '補助雷達',
  description = '台灣政府補助聚合平台，快速找到您符合資格的住宅、能源、教育及創業補助。'
} = Astro.props;

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

// Canonical URL for OG tags — Astro.url.href is set per-page by the static build.
// Note: hash-based deep-links (e.g. #card=xyz from the share button) cannot have
// per-card OG tags in a static build; all shares resolve to this site-level preview.
// Per-card OG would require pre-rendered /subsidies/[id].astro routes or SSR.
const siteOrigin = Astro.site?.origin ?? 'https://copilot-autogent.github.io';
const canonicalUrl = Astro.url.href;
const ogImage = `${siteOrigin}${base}og-image.png`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="zh_TW" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="manifest" href={`${base}manifest.json`} />
    <meta name="theme-color" content="#2563eb" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-inner">
        <a href={base} class="logo">📡 補助雷達</a>
        <span class="tagline">台灣政府補助一站查詢</span>
        <a href={`${base}calendar`} class="nav-calendar-link" id="navCalendarLink">📅 截止日曆</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p>資料來源：內政部國土管理署、各縣市政府官方網站。本站僅供參考，請以官方公告為準。</p>
        <p>由 <a href="https://github.com/copilot-autogent/subsidy-radar" target="_blank" rel="noopener">補助雷達</a> 提供 · 開放原始碼</p>
      </div>
    </footer>
    <script define:vars={{ swUrl: `${base}sw.js`, swScope: base }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swUrl, { scope: swScope })
            .catch(err => console.warn('[subsidy-radar] SW registration failed:', err));
        });
      }
    </script>
  </body>
</html>
