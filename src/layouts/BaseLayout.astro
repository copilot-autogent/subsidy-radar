---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '補助雷達',
  description = '台灣政府補助聚合平台，快速找到您符合資格的住宅、能源、教育及創業補助。'
} = Astro.props;

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

// Canonical URL for OG tags — Astro.url.href is set per-page by the static build.
// Note: hash-based deep-links (e.g. #card=xyz from the share button) cannot have
// per-card OG tags in a static build; all shares resolve to this site-level preview.
// Per-card OG would require pre-rendered /subsidies/[id].astro routes or SSR.
const siteOrigin = Astro.site?.origin ?? 'https://copilot-autogent.github.io';
const canonicalUrl = Astro.url.href;
const ogImage = `${siteOrigin}${base}og-image.png`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="zh_TW" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="manifest" href={`${base}manifest.json`} />
    <meta name="theme-color" content="#2563eb" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="補助雷達" />
    <link rel="apple-touch-icon" href={`${base}icons/icon-192.png`} />
    <title>{title}</title>
    <!-- FAWT prevention: apply saved theme before CSS renders -->
    <script is:inline>
      (function() {
        var saved = null;
        try { saved = localStorage.getItem('theme'); } catch(e) {}
        if (saved === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else if (saved === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          // 'system', null, or unknown value — follow prefers-color-scheme
          document.documentElement.setAttribute(
            'data-theme',
            window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
          );
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <!-- Offline indicator: shown when navigator.onLine is false -->
    <div id="offline-indicator" class="offline-indicator" aria-live="polite" aria-label="離線模式" hidden>
      📵 離線模式
    </div>
    <!-- Install prompt: shown on Android Chrome when beforeinstallprompt fires -->
    <div id="install-banner" class="install-banner" hidden>
      <span>📲 安裝 APP — 加到主畫面，隨時查詢補助</span>
      <button id="install-btn" type="button">安裝</button>
      <button id="install-dismiss" type="button" aria-label="關閉安裝提示">✕</button>
    </div>
    <header class="site-header">
      <nav class="nav-inner">
        <a href={base} class="logo">📡 補助雷達</a>
        <span class="tagline">台灣政府補助一站查詢</span>
        <a href={`${base}calendar`} class="nav-calendar-link">📅 截止日曆</a>
        <a href={`${base}timeline`} class="nav-timeline-link">🗓️ 申請時程表</a>
        <button
          class="theme-toggle"
          id="theme-toggle"
          aria-label="切換深色模式"
          title="切換深色模式"
          type="button"
        >🌙</button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p>資料來源：內政部國土管理署、各縣市政府官方網站。本站僅供參考，請以官方公告為準。</p>
        <p class="footer-freshness-notice">⚠️ 補助資料由自動化代理人維護，請以官方網站為準。</p>
        <p>由 <a href="https://github.com/copilot-autogent/subsidy-radar" target="_blank" rel="noopener">補助雷達</a> 提供 · 開放原始碼</p>
      </div>
    </footer>
    <script define:vars={{ swUrl: `${base}sw.js`, swScope: base }}>
      // ── Service worker registration ──────────────────────────────────────────
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swUrl, { scope: swScope })
            .catch(err => console.warn('[subsidy-radar] SW registration failed:', err));
        });
      }

      // ── Offline indicator ────────────────────────────────────────────────────
      (function() {
        var indicator = document.getElementById('offline-indicator');
        if (!indicator) return;

        function updateOnlineStatus() {
          if (navigator.onLine) {
            indicator.setAttribute('hidden', '');
          } else {
            indicator.removeAttribute('hidden');
          }
        }

        updateOnlineStatus();
        window.addEventListener('online', updateOnlineStatus);
        window.addEventListener('offline', updateOnlineStatus);
      })();

      // ── PWA install prompt (Android Chrome) ──────────────────────────────────
      (function() {
        var deferredPrompt = null;
        var banner = document.getElementById('install-banner');
        var installBtn = document.getElementById('install-btn');
        var dismissBtn = document.getElementById('install-dismiss');

        // Check if user already dismissed
        var dismissed = false;
        try { dismissed = !!localStorage.getItem('pwa-install-dismissed'); } catch(e) {}
        if (dismissed) return;

        window.addEventListener('beforeinstallprompt', function(e) {
          e.preventDefault();
          deferredPrompt = e;
          if (banner) banner.removeAttribute('hidden');
        });

        if (installBtn) {
          installBtn.addEventListener('click', function() {
            if (!deferredPrompt) return;
            deferredPrompt.prompt();
            deferredPrompt.userChoice.then(function() {
              deferredPrompt = null;
              if (banner) banner.setAttribute('hidden', '');
            }).catch(function() {
              deferredPrompt = null;
            });
          });
        }

        if (dismissBtn) {
          dismissBtn.addEventListener('click', function() {
            if (banner) banner.setAttribute('hidden', '');
            try { localStorage.setItem('pwa-install-dismissed', '1'); } catch(e) {}
          });
        }

        // Hide banner once installed
        window.addEventListener('appinstalled', function() {
          if (banner) banner.setAttribute('hidden', '');
        });
      })();
    </script>
    <script>
      // Theme toggle logic
      (function() {
        var btn = document.getElementById('theme-toggle');

        function getEffectiveTheme() {
          try {
            var saved = localStorage.getItem('theme');
            if (saved === 'dark') return 'dark';
            if (saved === 'light') return 'light';
          } catch(e) {}
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        function applyTheme(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          if (btn) {
            btn.textContent = theme === 'dark' ? '☀️' : '🌙';
            btn.setAttribute('aria-label', theme === 'dark' ? '切換至淺色模式' : '切換至深色模式');
            btn.setAttribute('title', theme === 'dark' ? '切換至淺色模式' : '切換至深色模式');
            btn.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
          }
        }

        // Enable transitions after first paint (prevents flash-of-transition on load)
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            document.documentElement.classList.add('theme-ready');
          });
        });

        // Set initial icon/state
        applyTheme(getEffectiveTheme());

        if (btn) {
          btn.addEventListener('click', function() {
            var current = document.documentElement.getAttribute('data-theme');
            var next = current === 'dark' ? 'light' : 'dark';
            try { localStorage.setItem('theme', next); } catch(e) {}
            applyTheme(next);
          });
        }

        // Sync with system preference changes (when no saved override)
        try {
          var mq = window.matchMedia('(prefers-color-scheme: dark)');
          var mqHandler = function(e) {
            try {
              var saved = localStorage.getItem('theme');
              if (!saved || saved === 'system') {
                applyTheme(e.matches ? 'dark' : 'light');
              }
            } catch(e2) {}
          };
          if (mq.addEventListener) {
            mq.addEventListener('change', mqHandler);
          } else if (mq.addListener) {
            mq.addListener(mqHandler); // Safari <14 fallback
          }
        } catch(e) {}
      })();
    </script>
  </body>
</html>
