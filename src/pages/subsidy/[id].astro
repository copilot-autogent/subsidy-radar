---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  subsidies,
  getFreshnessBadge,
  getRelatedSubsidies,
  safeUrl,
  deadlineLabel,
  difficultyLabel,
  situationLabel,
} from '../../utils/subsidies.ts';

export function getStaticPaths() {
  return subsidies.map(s => ({ params: { id: s.id } }));
}

const { id } = Astro.params;
// getStaticPaths guarantees id is always valid; find is just for type narrowing
const subsidy = subsidies.find(s => s.id === id)!;

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const siteOrigin = Astro.site?.origin ?? new URL(import.meta.env.BASE_URL || '/', 'https://example.com').origin;

const freshness = getFreshnessBadge(subsidy.lastVerifiedDate);
const deadline = deadlineLabel[subsidy.deadlineStatus] ?? { text: subsidy.deadlineStatus, cls: 'status-ongoing' };
const diff = difficultyLabel[subsidy.difficulty ?? 'medium'];
const officialHref = safeUrl(subsidy.officialUrl);
const appHref = safeUrl(subsidy.applicationUrl);
const sourceHref = safeUrl(subsidy.source);

const related = getRelatedSubsidies(subsidy, subsidies);

// Canonical URL for this detail page
const canonicalUrl = `${siteOrigin}${base}subsidy/${subsidy.id}/`;

// Per-page OG image falls back to site-level OG image
const ogImage = `${siteOrigin}${base}og-image.png`;

// JSON-LD GovernmentService structured data
const jsonLdRaw = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'GovernmentService',
  name: subsidy.title,
  description: subsidy.summary,
  url: canonicalUrl,
  provider: {
    '@type': 'GovernmentOrganization',
    name: subsidy.agency,
  },
  ...(officialHref ? { serviceUrl: officialHref } : {}),
});
const jsonLd = jsonLdRaw.replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');

const pageTitle = `${subsidy.title} — 補助雷達`;
const pageDescription = subsidy.summary;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <div class="detail-page">
    <!-- Breadcrumb / back link -->
    <nav class="breadcrumb" aria-label="麵包屑導覽">
      <a href={base} class="back-link">← 返回補助列表</a>
    </nav>

    <article class="detail-card" id={subsidy.id}>
      <!-- Header: title + badges -->
      <header class="detail-header">
        <div class="detail-meta-row">
          <span class="detail-category-badge">{subsidy.category}</span>
          <span class={`detail-deadline-badge ${deadline.cls}`}>{deadline.text}</span>
          {diff && <span class={`detail-diff-badge ${diff.cls}`} title={diff.tooltip}>{diff.text}</span>}
          <span class={`detail-freshness ${freshness.cls}`}>{freshness.label}</span>
        </div>
        <h1 class="detail-title">{subsidy.title}</h1>
        <p class="detail-agency">🏛️ {subsidy.agency}</p>
        <p class="detail-summary">{subsidy.summary}</p>

        <!-- Situation chips -->
        {(subsidy.situations ?? []).length > 0 && (
          <div class="detail-situations" aria-label="適用對象">
            {(subsidy.situations ?? []).map(sit => {
              const info = situationLabel[sit];
              return info
                ? <span class="situation-chip">{info.icon} {info.label}</span>
                : <span class="situation-chip">{sit}</span>;
            })}
          </div>
        )}
      </header>

      <!-- Amount -->
      <section class="detail-section" aria-label="補助金額">
        <h2 class="section-heading">💰 補助金額</h2>
        <p class="detail-amount">{subsidy.amount}</p>
      </section>

      <!-- Eligibility -->
      {(subsidy.eligibility ?? []).length > 0 && (
        <section class="detail-section" aria-label="申請資格">
          <h2 class="section-heading">✅ 申請資格</h2>
          <ul class="detail-list eligibility-list">
            {(subsidy.eligibility ?? []).map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      <!-- Application steps -->
      {(subsidy.steps ?? []).length > 0 && (
        <section class="detail-section" aria-label="申請步驟">
          <h2 class="section-heading">📋 申請步驟</h2>
          <ol class="detail-list steps-list">
            {(subsidy.steps ?? []).map(step => (
              <li>{step}</li>
            ))}
          </ol>
        </section>
      )}

      <!-- Required documents -->
      {(subsidy.requiredDocs ?? []).length > 0 && (
        <section class="detail-section" aria-label="所需文件">
          <h2 class="section-heading">📎 所需文件</h2>
          <ul class="detail-list docs-list">
            {(subsidy.requiredDocs ?? []).map(doc => (
              <li>{doc}</li>
            ))}
          </ul>
        </section>
      )}

      <!-- Deadline detail -->
      <section class="detail-section" aria-label="申請期限">
        <h2 class="section-heading">📅 申請期限</h2>
        <p>{subsidy.deadline}</p>
        {subsidy.deadlineDate && (
          <p class="deadline-date-detail">截止日期：{subsidy.deadlineDate}</p>
        )}
      </section>

      <!-- Counties if present -->
      {(subsidy.counties ?? []).length > 0 && (
        <section class="detail-section" aria-label="適用縣市">
          <h2 class="section-heading">📍 適用縣市</h2>
          <div class="counties-chips">
            {(subsidy.counties ?? []).map(c => <span class="county-chip">{c}</span>)}
          </div>
        </section>
      )}

      <!-- CTA buttons -->
      <div class="detail-cta-row">
        {officialHref && (
          <a href={officialHref} class="cta-primary" target="_blank" rel="noopener noreferrer">
            🔗 查看官方頁面
          </a>
        )}
        {appHref && (
          <a href={appHref} class="cta-secondary" target="_blank" rel="noopener noreferrer">
            📝 立即申請
          </a>
        )}
      </div>

      <!-- Source / last verified -->
      {sourceHref && (
        <p class="detail-source">
          資料來源：<a href={sourceHref} target="_blank" rel="noopener noreferrer">{sourceHref}</a>
        </p>
      )}
    </article>

    <!-- Related subsidies -->
    {related.length > 0 && (
      <aside class="related-section" aria-label="相關補助">
        <h2 class="related-heading">🔗 相關補助</h2>
        <div class="related-grid">
          {related.map(r => {
            const rDl = deadlineLabel[r.deadlineStatus] ?? { text: r.deadlineStatus, cls: 'status-ongoing' };
            return (
              <a href={`${base}subsidy/${r.id}/`} class="related-card">
                <div class="related-card-meta">
                  <span class="related-category">{r.category}</span>
                  <span class={`related-status ${rDl.cls}`}>{rDl.text}</span>
                </div>
                <p class="related-title">{r.title}</p>
                <p class="related-agency">{r.agency}</p>
              </a>
            );
          })}
        </div>
      </aside>
    )}

    <!-- Bottom back link -->
    <div class="detail-footer-nav">
      <a href={base} class="back-link">← 返回補助列表</a>
    </div>
  </div>
</BaseLayout>

<style>
  .detail-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .breadcrumb {
    margin-bottom: 1.25rem;
  }

  .back-link {
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .back-link:hover {
    text-decoration: underline;
  }

  /* ── Detail card ─────────────────────────────────────────────── */
  .detail-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.75rem;
    margin-bottom: 2rem;
  }

  .detail-header {
    margin-bottom: 1.5rem;
  }

  .detail-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .detail-category-badge {
    background: var(--color-primary-light);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .detail-deadline-badge {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .status-open     { background: #dcfce7; color: #166534; }
  .status-ongoing  { background: #dbeafe; color: #1e40af; }
  .status-periodic { background: #fef9c3; color: #854d0e; }
  .status-closed   { background: #fee2e2; color: #991b1b; }

  [data-theme="dark"] .status-open     { background: #14532d; color: #86efac; }
  [data-theme="dark"] .status-ongoing  { background: #1e3a5f; color: #93c5fd; }
  [data-theme="dark"] .status-periodic { background: #422006; color: #fde68a; }
  [data-theme="dark"] .status-closed   { background: #450a0a; color: #fca5a5; }

  .detail-diff-badge {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    cursor: help;
  }

  .diff-easy   { background: #dcfce7; color: #166534; }
  .diff-medium { background: #fef9c3; color: #854d0e; }
  .diff-hard   { background: #fee2e2; color: #991b1b; }

  [data-theme="dark"] .diff-easy   { background: #14532d; color: #86efac; }
  [data-theme="dark"] .diff-medium { background: #422006; color: #fde68a; }
  [data-theme="dark"] .diff-hard   { background: #450a0a; color: #fca5a5; }

  .detail-freshness {
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
    font-weight: 500;
  }
  .freshness-fresh   { background: #dcfce7; color: #166534; }
  .freshness-stale   { background: #fef9c3; color: #854d0e; }
  .freshness-outdated{ background: #fee2e2; color: #991b1b; }

  [data-theme="dark"] .freshness-fresh    { background: #14532d; color: #86efac; }
  [data-theme="dark"] .freshness-stale    { background: #422006; color: #fde68a; }
  [data-theme="dark"] .freshness-outdated { background: #450a0a; color: #fca5a5; }

  .detail-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0.25rem 0 0.5rem;
    line-height: 1.3;
  }

  .detail-agency {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .detail-summary {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .detail-situations {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .situation-chip {
    background: var(--color-tag);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    border: 1px solid var(--color-border);
  }

  /* ── Sections ────────────────────────────────────────────────── */
  .detail-section {
    margin-bottom: 1.5rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .detail-amount {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .detail-list {
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .detail-list li {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .steps-list {
    counter-reset: steps;
  }

  .deadline-date-detail {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .counties-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .county-chip {
    background: var(--color-tag);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-size: 0.82rem;
    padding: 0.2rem 0.6rem;
    color: var(--color-text-muted);
  }

  /* ── CTA row ─────────────────────────────────────────────────── */
  .detail-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .cta-primary:hover,
  .cta-secondary:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .cta-primary {
    background: var(--color-primary);
    color: #fff;
  }
  .cta-secondary {
    background: var(--color-primary-light);
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
  }

  .detail-source {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
    word-break: break-all;
  }

  /* ── Related section ─────────────────────────────────────────── */
  .related-section {
    margin-bottom: 2rem;
  }

  .related-heading {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .related-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
    text-decoration: none;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .related-card:hover {
    box-shadow: var(--shadow-hover);
    border-color: var(--color-primary);
    text-decoration: none;
  }

  .related-card-meta {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .related-category {
    background: var(--color-primary-light);
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 20px;
  }

  .related-status {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.15rem 0.45rem;
    border-radius: 20px;
  }

  .related-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
    line-height: 1.4;
  }

  .related-agency {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  /* ── Footer nav ──────────────────────────────────────────────── */
  .detail-footer-nav {
    margin-top: 1rem;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .detail-card {
      padding: 1.25rem;
    }
    .detail-title {
      font-size: 1.3rem;
    }
    .detail-cta-row {
      flex-direction: column;
    }
    .cta-primary,
    .cta-secondary {
      justify-content: center;
    }
  }
</style>
