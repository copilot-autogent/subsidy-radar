---
import BaseLayout from '../layouts/BaseLayout.astro';
import subsidiesRaw from '../data/subsidies.json';

type Subsidy = typeof subsidiesRaw[number] & { isYouthHighlight?: boolean; difficulty?: string; steps?: string[] };
const subsidies = subsidiesRaw as Subsidy[];
const categories = ['全部', '⭐ 青年必看', ...new Set(subsidies.map(s => s.category))];
const youthCount = subsidies.filter(s => s.isYouthHighlight).length;

const deadlineLabel: Record<string, { text: string; cls: string }> = {
  open:     { text: '✅ 開放申請中', cls: 'status-open' },
  ongoing:  { text: '🔄 長期辦理',   cls: 'status-ongoing' },
  periodic: { text: '📅 定期開放',   cls: 'status-periodic' },
};

const difficultyLabel: Record<string, { text: string; cls: string; tooltip: string }> = {
  easy:   { text: '🟢 申請簡單', cls: 'diff-easy',   tooltip: '線上申請，約5-10分鐘可完成' },
  medium: { text: '🟡 需備文件', cls: 'diff-medium', tooltip: '需備齊紙本文件，約1-2週處理' },
  hard:   { text: '🔴 流程複雜', cls: 'diff-hard',   tooltip: '多步驟審核流程，建議先電話諮詢' },
};

const personas = [
  { key: 'fresh-grad',  icon: '🎓', label: '應屆畢業生' },
  { key: 'renter',      icon: '🏠', label: '找租屋' },
  { key: 'homebuyer',   icon: '🏡', label: '想買房' },
  { key: 'entrepreneur',icon: '💼', label: '想創業' },
  { key: 'parent',      icon: '👶', label: '育兒家庭' },
];
---

<BaseLayout
  title="補助雷達 — 台灣政府補助一站查詢"
  description="快速查詢台灣政府補助資訊，包含就業、創業、住宅等補助，找到您符合資格的補助方案。"
>

  <section class="hero">
    <h1>📡 補助雷達</h1>
    <p>快速找到您符合資格的台灣政府補助，包含就業、創業、住宅及生活補助。</p>
    <p class="hero-youth-hint">🎓 剛畢業？先看「<strong>青年必看</strong>」，{youthCount} 項補助等你領！</p>
  </section>

  <section class="persona-section" aria-label="情況快速篩選">
    <p class="persona-label">我目前的情況是…</p>
    <div class="persona-buttons">
      {personas.map(p => (
        <button class="persona-btn" data-situation={p.key} type="button">
          <span class="persona-icon">{p.icon}</span>
          <span class="persona-text">{p.label}</span>
        </button>
      ))}
    </div>
  </section>

  <div class="controls">
    <div class="search-box">
      <span class="search-icon">🔍</span>
      <input
        type="search"
        id="searchInput"
        placeholder="搜尋補助名稱、類別或關鍵字…"
        aria-label="搜尋補助"
        autocomplete="off"
      />
    </div>
    <div class="category-filters" role="group" aria-label="類別篩選">
      {categories.map(cat => (
        <button
          class={`filter-btn ${cat === '全部' ? 'active' : ''} ${cat === '⭐ 青年必看' ? 'youth-filter' : ''}`}
          data-category={cat}
          type="button"
        >
          {cat}
        </button>
      ))}
    </div>
    <div class="sort-row">
      <button class="sort-btn" id="sortDifficulty" type="button" aria-pressed="false">
        依申請難度排序
      </button>
      <button class="sort-btn tracker-filter-btn" id="trackerFilter" type="button" aria-pressed="false">
        📌 只看追蹤中
      </button>
    </div>
  </div>

  <div class="eligibility-banner" id="eligibilityBanner" style="display:none" role="status" aria-live="polite">
    <span class="banner-emoji">🎯</span>
    <span id="bannerText"></span>
  </div>

  <p class="results-count" id="resultsCount">共 {subsidies.length} 項補助</p>

  <div class="grid" id="subsidyGrid">
    {subsidies.map(s => {
      const status = deadlineLabel[s.deadlineStatus] ?? deadlineLabel['ongoing'];
      const diff = difficultyLabel[s.difficulty ?? 'medium'];
      return (
        <article
          class={`subsidy-card ${s.isYouthHighlight ? 'youth-highlight' : ''}`}
          data-category={s.category}
          data-youth={s.isYouthHighlight ? 'true' : 'false'}
          data-situations={JSON.stringify(s.situations ?? [])}
          data-difficulty={s.difficulty ?? 'medium'}
          data-search={`${s.title} ${s.summary} ${s.tags.join(' ')} ${s.agency}`}
          data-id={s.id}
        >
          <div class="card-header">
            <h2 class="card-title">{s.title}</h2>
            <div class="card-badges">
              {s.isYouthHighlight && <span class="youth-badge">⭐ 青年必看</span>}
              <span class="category-badge">{s.category}</span>
            </div>
            <button class="tracker-btn" data-id={s.id} title="點擊更新申請進度" type="button" aria-label="更新申請狀態">
              <span class="tracker-label">未申請</span>
            </button>
          </div>
          <p class="card-agency">📋 {s.agency}</p>
          <div class="card-amount-highlight">
            <span class="amount-icon">💰</span>
            <span class="amount-text">{s.amount}</span>
          </div>
          <p class="card-summary">{s.summary}</p>
          <div class="card-meta-row">
            <div class="card-deadline">
              <span class={`deadline-status ${status.cls}`}>{status.text}</span>
              <span class="deadline-text">🗓️ {s.deadline}</span>
            </div>
            <span class={`difficulty-badge ${diff.cls}`} data-tooltip={diff.tooltip}>{diff.text}</span>
          </div>
          <details class="card-eligibility">
            <summary>申請資格條件</summary>
            <ul>
              {s.eligibility.map(e => <li>{e}</li>)}
            </ul>
          </details>
          <div class="card-tags">
            {s.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
          {s.steps && s.steps.length > 0 && (
            <details class="card-steps">
              <summary>📋 如何申請？（{s.steps.length} 個步驟）</summary>
              <ol class="steps-list">
                {s.steps.map(step => <li>{step}</li>)}
              </ol>
            </details>
          )}
          <a href={s.applicationUrl} target="_blank" rel="noopener noreferrer" class="card-link">立即申請 →</a>
        </article>
      );
    })}
    <div class="no-results" id="noResults" style="display:none">找不到符合條件的補助，請嘗試其他關鍵字。</div>
  </div>

  <script>
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const personaBtns = document.querySelectorAll<HTMLButtonElement>('.persona-btn');
    const cards = document.querySelectorAll<HTMLElement>('.subsidy-card');
    const resultsCount = document.getElementById('resultsCount')!;
    const noResults = document.getElementById('noResults')!;
    const eligibilityBanner = document.getElementById('eligibilityBanner')!;
    const bannerText = document.getElementById('bannerText')!;
    const sortBtn = document.getElementById('sortDifficulty') as HTMLButtonElement;
    const trackerFilterBtn = document.getElementById('trackerFilter') as HTMLButtonElement;

    let activeCategory = '全部';
    let activeSituation = '';
    let searchQuery = '';
    let sortByDifficulty = false;
    let showTrackedOnly = false;

    const difficultyOrder: Record<string, number> = { easy: 1, medium: 2, hard: 3 };

    // ── Tracker ──────────────────────────────────────────────────────────────
    const TRACKER_KEY = 'subsidy-tracker-v1';
    const STATUS_CYCLE = ['未申請', '已申請', '進行中', '已完成'] as const;
    type TrackerStatus = typeof STATUS_CYCLE[number];
    const STATUS_CLASS: Record<TrackerStatus, string> = {
      '未申請': 'ts-none',
      '已申請': 'ts-applied',
      '進行中': 'ts-inprogress',
      '已完成': 'ts-done',
    };

    function loadTracker(): Record<string, TrackerStatus> {
      try { return JSON.parse(localStorage.getItem(TRACKER_KEY) ?? '{}'); }
      catch { return {}; }
    }

    function saveTracker(tracker: Record<string, TrackerStatus>) {
      localStorage.setItem(TRACKER_KEY, JSON.stringify(tracker));
    }

    function applyTrackerToBtn(btn: HTMLButtonElement, status: TrackerStatus) {
      const label = btn.querySelector<HTMLElement>('.tracker-label')!;
      label.textContent = status;
      btn.className = `tracker-btn ${STATUS_CLASS[status]}`;
      btn.title = `申請進度：${status}（點擊切換）`;
    }

    function initTracker() {
      const tracker = loadTracker();
      document.querySelectorAll<HTMLButtonElement>('.tracker-btn').forEach(btn => {
        const id = btn.dataset.id!;
        const status: TrackerStatus = tracker[id] ?? '未申請';
        applyTrackerToBtn(btn, status);
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const t = loadTracker();
          const cur: TrackerStatus = t[id] ?? '未申請';
          const next = STATUS_CYCLE[(STATUS_CYCLE.indexOf(cur) + 1) % STATUS_CYCLE.length];
          t[id] = next;
          saveTracker(t);
          applyTrackerToBtn(btn, next);
          updateTrackerFilterLabel();
          if (showTrackedOnly) updateDisplay();
        });
      });
    }

    function countTracked(): number {
      const tracker = loadTracker();
      return Object.values(tracker).filter(s => s !== '未申請').length;
    }

    function updateTrackerFilterLabel() {
      const n = countTracked();
      trackerFilterBtn.textContent = showTrackedOnly
        ? `✓ 📌 追蹤中 (${n})`
        : `📌 只看追蹤中${n > 0 ? ` (${n})` : ''}`;
      trackerFilterBtn.classList.toggle('active', showTrackedOnly);
      trackerFilterBtn.setAttribute('aria-pressed', String(showTrackedOnly));
    }

    // ── Sort ─────────────────────────────────────────────────────────────────
    function applySort() {
      cards.forEach(card => {
        if (sortByDifficulty) {
          const diff = card.dataset.difficulty ?? 'medium';
          card.style.order = String(difficultyOrder[diff] ?? 2);
        } else {
          card.style.order = '';
        }
      });
    }

    // ── Display ──────────────────────────────────────────────────────────────
    function countEligible(situation: string): number {
      return Array.from(cards).filter(card => {
        const situations: string[] = JSON.parse(card.dataset.situations ?? '[]');
        return situations.includes(situation);
      }).length;
    }

    function updateDisplay() {
      const tracker = loadTracker();
      let visible = 0;
      cards.forEach(card => {
        const cat = card.dataset.category ?? '';
        const isYouth = card.dataset.youth === 'true';
        const situations: string[] = JSON.parse(card.dataset.situations ?? '[]');
        const search = (card.dataset.search ?? '').toLowerCase();
        const cardId = card.dataset.id ?? '';

        const matchCat = activeCategory === '全部'
          ? true
          : activeCategory === '⭐ 青年必看'
          ? isYouth
          : cat === activeCategory;

        const matchSituation = activeSituation === '' || situations.includes(activeSituation);
        const matchSearch = searchQuery === '' || search.includes(searchQuery);
        const matchTracked = !showTrackedOnly || (tracker[cardId] && tracker[cardId] !== '未申請');

        const show = matchCat && matchSituation && matchSearch && matchTracked;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      resultsCount.textContent = `共 ${visible} 項補助`;
      noResults.style.display = visible === 0 ? 'block' : 'none';

      if (activeSituation) {
        const totalEligible = countEligible(activeSituation);
        bannerText.textContent = `你可能有 ${totalEligible} 項補助符合你的情況！`;
        eligibilityBanner.style.display = 'flex';
      } else {
        eligibilityBanner.style.display = 'none';
      }
    }

    // ── Event listeners ──────────────────────────────────────────────────────
    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value.trim().toLowerCase();
      updateDisplay();
    });

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.dataset.category ?? '全部';
        activeSituation = '';
        personaBtns.forEach(b => b.classList.remove('active'));
        updateDisplay();
      });
    });

    personaBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const situation = btn.dataset.situation ?? '';
        if (activeSituation === situation) {
          activeSituation = '';
          btn.classList.remove('active');
        } else {
          activeSituation = situation;
          personaBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeCategory = '全部';
          filterBtns.forEach(b => b.classList.remove('active'));
          filterBtns[0]?.classList.add('active');
        }
        updateDisplay();
      });
    });

    sortBtn.addEventListener('click', () => {
      sortByDifficulty = !sortByDifficulty;
      sortBtn.classList.toggle('active', sortByDifficulty);
      sortBtn.setAttribute('aria-pressed', String(sortByDifficulty));
      sortBtn.textContent = sortByDifficulty ? '✓ 🟢 簡單優先' : '依申請難度排序';
      applySort();
    });

    trackerFilterBtn.addEventListener('click', () => {
      showTrackedOnly = !showTrackedOnly;
      updateTrackerFilterLabel();
      updateDisplay();
    });

    // ── Init ─────────────────────────────────────────────────────────────────
    initTracker();
    updateTrackerFilterLabel();
  </script>
</BaseLayout>
