---
import BaseLayout from '../layouts/BaseLayout.astro';
import subsidiesRaw from '../data/subsidies.json';

type Situation = 'renter' | 'homebuyer' | 'entrepreneur' | 'parent' | 'fresh-grad' | 'unemployed' | 'employed' | 'senior' | 'disabled' | 'new-immigrant' | 'indigenous' | 'low-income' | 'single-parent' | 'young-child' | 'student' | 'worker' | 'middle-aged' | 'veteran' | 'farmer';
type Subsidy = typeof subsidiesRaw[number] & { isYouthHighlight?: boolean; difficulty?: string; steps?: string[]; deadlineDate?: string; addedDate?: string; situations?: Situation[]; maxAmount?: number; counties?: string[]; requiredDocs?: string[]; officialUrl?: string; lastVerifiedDate?: string; source?: string };
const subsidies = subsidiesRaw as Subsidy[];

// ── Data freshness badge helper ───────────────────────────────────────────
// NOTE: BUILD_DATE is fixed at Astro build time. Freshness thresholds are
// evaluated once and baked into the HTML. The site must be rebuilt periodically
// (e.g. via scheduled CI) so that badges don't permanently overstate freshness.
const BUILD_DATE = new Date(); BUILD_DATE.setHours(0, 0, 0, 0);

/**
 * Returns the number of whole calendar months between a verified date and
 * BUILD_DATE, accounting for the day-of-month so that e.g. April 30 → July 1
 * counts as 2 months (not 3).
 */
function calendarMonthsAgo(verifiedYear: number, verifiedMonth: number, verifiedDay: number): number {
  let months = (BUILD_DATE.getFullYear() - verifiedYear) * 12 +
    (BUILD_DATE.getMonth() + 1 - verifiedMonth);
  // Subtract 1 if we haven't yet reached the same day-of-month in the build month
  if (BUILD_DATE.getDate() < verifiedDay) months -= 1;
  return months;
}

/** Returns { cls, label } for the data freshness badge. */
function getFreshnessBadge(lastVerifiedDate: string | null | undefined): { cls: string; label: string } {
  if (!lastVerifiedDate) {
    return { cls: 'freshness-outdated', label: '⚠️ 未核實' };
  }
  const parts = lastVerifiedDate.split('-').map(Number);
  const [y, m, d] = parts;
  // Validate: must be YYYY-MM-DD with sane ranges and no future date
  const verified = new Date(y, m - 1, d);
  const isValid =
    parts.length === 3 &&
    Number.isFinite(y) && Number.isFinite(m) && Number.isFinite(d) &&
    m >= 1 && m <= 12 && d >= 1 && d <= 31 &&
    verified.getFullYear() === y && verified.getMonth() === m - 1 && verified.getDate() === d &&
    verified <= BUILD_DATE;
  if (!isValid) {
    return { cls: 'freshness-outdated', label: '⚠️ 未核實' };
  }
  const monthsAgo = calendarMonthsAgo(y, m, d);
  const label = `✓ 已核實 ${String(y)}-${String(m).padStart(2, '0')}`;
  if (monthsAgo < 3) return { cls: 'freshness-fresh', label };
  if (monthsAgo <= 6) return { cls: 'freshness-stale', label };
  return { cls: 'freshness-outdated', label: `⚠️ ${label}` };
}

// ── Related subsidies: build-time pre-computation ─────────────────────────
// Algorithm: find top 2-3 other subsidies sharing the most `situations` tags.
// Ties broken by difficulty: easier (easy < medium < hard) comes first.
const DIFFICULTY_ORDER: Record<string, number> = { easy: 0, medium: 1, hard: 2 };

// Only allow http/https scheme URLs to prevent javascript: injection.
// Returns the trimmed URL if safe, otherwise undefined.
function safeUrl(url: string | undefined): string | undefined {
  if (!url) return undefined;
  const trimmed = url.trimStart();
  const lower = trimmed.toLowerCase();
  return lower.startsWith('https://') || lower.startsWith('http://') ? trimmed : undefined;
}

function getRelatedSubsidies(subsidy: Subsidy, all: Subsidy[], max = 3): Subsidy[] {
  const mySituations = new Set<string>(subsidy.situations ?? []);
  if (mySituations.size === 0) return [];
  return all
    .filter(s => s.id !== subsidy.id)
    .map(s => ({ s, shared: (s.situations ?? []).filter(sit => mySituations.has(sit)).length }))
    .filter(({ shared }) => shared > 0)
    .sort((a, b) =>
      b.shared - a.shared ||
      (DIFFICULTY_ORDER[a.s.difficulty ?? 'medium'] ?? 1) - (DIFFICULTY_ORDER[b.s.difficulty ?? 'medium'] ?? 1)
    )
    .map(({ s }) => s)
    .slice(0, max);
}

const relatedMap = new Map<string, Subsidy[]>();
subsidies.forEach(s => relatedMap.set(s.id, getRelatedSubsidies(s, subsidies)));
// ─────────────────────────────────────────────────────────────────────────

// Compute category counts for filter buttons
const categoryCounts: Record<string, number> = {};
subsidies.forEach(s => {
  categoryCounts[s.category] = (categoryCounts[s.category] || 0) + 1;
});
const youthHighlightCount = subsidies.filter(s => s.isYouthHighlight).length;
const seniorCount = subsidies.filter(s => s.situations?.includes('senior') || s.category === '長者').length;

const RECENCY_DAYS = 90;
const RECENCY_LABEL = '🆕 最新';
const now = new Date(); now.setHours(0, 0, 0, 0);
const recencyCount = subsidies.filter(s => {
  if (!s.addedDate) return false;
  const [y, m, d] = s.addedDate.split('-').map(Number);
  if (!Number.isFinite(y) || !Number.isFinite(m) || !Number.isFinite(d)) return false;
  if (m < 1 || m > 12 || d < 1 || d > 31) return false;
  const added = new Date(y, m - 1, d);
  if (added.getFullYear() !== y || added.getMonth() !== m - 1 || added.getDate() !== d) return false;
  const diff = Math.floor((now.getTime() - added.getTime()) / 86400000);
  return diff >= 0 && diff <= RECENCY_DAYS;
}).length;
const SENIOR_LABEL = '⭐ 長者照護';
const SENIOR_CATEGORY = '長者';
const DISABILITY_LABEL = '⭐ 身障';
const disabledCount = subsidies.filter(s => s.situations?.includes('disabled')).length;
const NEW_IMMIGRANT_LABEL = '⭐ 新住民';
const newImmigrantCount = subsidies.filter(s => s.situations?.includes('new-immigrant')).length;
const INDIGENOUS_LABEL = '⭐ 原住民';
const indigenousCount = subsidies.filter(s => s.situations?.includes('indigenous')).length;
const LOW_INCOME_LABEL = '⭐ 低/中低收入戶';
const lowIncomeCount = subsidies.filter(s => s.situations?.includes('low-income')).length;
const SINGLE_PARENT_LABEL = '⭐ 單親';
const singleParentCount = subsidies.filter(s => s.situations?.includes('single-parent')).length;
const YOUNG_CHILD_LABEL = '⭐ 育兒';
const YOUNG_CHILD_CATEGORY = '育兒';
const youngChildCount = subsidies.filter(s => s.situations?.includes('young-child') || s.category === YOUNG_CHILD_CATEGORY).length;
const STUDENT_LABEL = '⭐ 學生補助';
const studentCount = subsidies.filter(s => s.situations?.includes('student')).length;
const WORKER_LABEL = '⭐ 勞工補助';
const workerCount = subsidies.filter(s => s.situations?.includes('worker')).length;
const MIDDLE_AGED_LABEL = '⭐ 中高齡補助';
const middleAgedCount = subsidies.filter(s => s.situations?.includes('middle-aged')).length;
const VETERAN_LABEL = '⭐ 榮民補助';
const veteranCount = subsidies.filter(s => s.situations?.includes('veteran')).length;
const FARMER_LABEL = '⭐ 農業補助';
const FARMER_CATEGORY = '農業';
const farmerCount = subsidies.filter(s => s.situations?.includes('farmer')).length;
const categories = ['全部', '⭐ 青年必看', SENIOR_LABEL, DISABILITY_LABEL, NEW_IMMIGRANT_LABEL, INDIGENOUS_LABEL, LOW_INCOME_LABEL, SINGLE_PARENT_LABEL, YOUNG_CHILD_LABEL, STUDENT_LABEL, WORKER_LABEL, MIDDLE_AGED_LABEL, VETERAN_LABEL, FARMER_LABEL, RECENCY_LABEL, ...new Set(subsidies.map(s => s.category).filter(c => c !== SENIOR_CATEGORY && c !== YOUNG_CHILD_CATEGORY && c !== FARMER_CATEGORY))];
const youthCount = youthHighlightCount;

// ── Agency filter — normalize full agency names to parent-ministry groups ─
function normalizeAgency(agency: string): string {
  if (!agency) return '其他';
  if (agency.startsWith('衛生福利部')) return '衛福部';
  if (agency.startsWith('勞動部')) return '勞動部';
  if (agency.startsWith('教育部')) return '教育部';
  if (agency.startsWith('內政部') || agency.startsWith('國家住宅及都市更新中心')) return '內政部';
  if (agency.startsWith('原住民族')) return '原民會';
  if (agency.startsWith('國家科學及技術委員會')) return '國科會';
  if (agency.startsWith('經濟部')) return '經濟部';
  if (agency.startsWith('財政部')) return '財政部';
  if (agency.startsWith('農業部')) return '農業部';
  if (agency.startsWith('各縣市')) return '各縣市';
  return '其他';
}

const agencyCounts: Record<string, number> = {};
subsidies.forEach(s => {
  const norm = normalizeAgency(s.agency);
  agencyCounts[norm] = (agencyCounts[norm] || 0) + 1;
});

// Display order: highest-count ministries first, then alphabetical
const AGENCY_DISPLAY_ORDER = ['勞動部', '衛福部', '內政部', '教育部', '原民會', '經濟部', '財政部', '農業部', '各縣市', '國科會', '其他'];
const agencies = AGENCY_DISPLAY_ORDER.filter(a => agencyCounts[a] > 0);

// Difficulty filter counts
const VALID_DIFFICULTIES = new Set(['easy', 'medium', 'hard']);
const difficultyCounts: Record<string, number> = { easy: 0, medium: 0, hard: 0 };
subsidies.forEach(s => {
  const d = (String(s.difficulty ?? 'medium')).trim().toLowerCase() || 'medium';
  if (VALID_DIFFICULTIES.has(d)) difficultyCounts[d]++;
});
const difficultyFilters = [
  { key: 'easy',   label: '🟢 簡單', cls: 'diff-easy-filter' },
  { key: 'medium', label: '🟡 中等', cls: 'diff-medium-filter' },
  { key: 'hard',   label: '🔴 困難', cls: 'diff-hard-filter' },
] as const;

const deadlineLabel: Record<string, { text: string; cls: string }> = {
  open:     { text: '✅ 開放申請中', cls: 'status-open' },
  ongoing:  { text: '🔄 長期辦理',   cls: 'status-ongoing' },
  periodic: { text: '📅 定期開放',   cls: 'status-periodic' },
  closed:   { text: '⏸ 已截止',      cls: 'status-closed' },
};

// Build-time amount parser: extracts the best numeric value from an amount string.
// Returns an integer (元), applying a ×12 annualisation for monthly (每月) amounts.
function parseAmountValue(amount: string): number {
  if (!amount) return 0;
  const text = amount.replace(/,/g, '');
  let maxValue = 0;
  let foundWan = false;

  // Match "N 萬" (e.g. 200萬, 1,000萬) → N × 10000
  const wanRe = /(\d+(?:\.\d+)?)\s*萬/g;
  let m: RegExpExecArray | null;
  while ((m = wanRe.exec(text)) !== null) {
    const v = parseFloat(m[1]) * 10000;
    if (v > maxValue) maxValue = v;
    foundWan = true;
  }

  // Match "N 元" not already captured by 萬 (e.g. 48,000 元)
  const yuanRe = /(\d+(?:\.\d+)?)\s*元/g;
  while ((m = yuanRe.exec(text)) !== null) {
    const v = parseFloat(m[1]);
    if (v > maxValue) maxValue = v;
  }

  if (maxValue === 0) return 0;

  // Annualise only when the dominant value is itself monthly (every-月 context):
  // — no 萬-scale amount found (those are always one-time grants/loans)
  // — "每月" appears somewhere in the string
  // — no explicit annual marker present
  // — the value paired with "每月" accounts for the overall max (guards against
  //   strings like "每月 5,000 元；上限 60,000 元" where the cap is larger)
  const hasAnnual = /每年|年省|全年/.test(amount);
  const hasMonthly = /每月/.test(amount);
  if (hasMonthly && !hasAnnual && !foundWan) {
    // Extract the maximum value that appears directly in a 每月 context
    const monthlyRe = /每月[^萬元]*?(\d[\d]*(?:\.\d+)?)\s*元/g;
    let monthlyMax = 0;
    let mm: RegExpExecArray | null;
    while ((mm = monthlyRe.exec(text)) !== null) {
      const v = parseFloat(mm[1]);
      if (v > monthlyMax) monthlyMax = v;
    }
    // Only multiply when the monthly value IS the global maximum
    if (monthlyMax > 0 && monthlyMax >= maxValue) maxValue *= 12;
  }

  return Math.round(maxValue);
}

const difficultyLabel: Record<string, { text: string; cls: string; tooltip: string }> = {
  easy:   { text: '🟢 申請簡單', cls: 'diff-easy',   tooltip: '線上申請，約5-10分鐘可完成' },
  medium: { text: '🟡 需備文件', cls: 'diff-medium', tooltip: '需備齊紙本文件，約1-2週處理' },
  hard:   { text: '🔴 流程複雜', cls: 'diff-hard',   tooltip: '多步驟審核流程，建議先電話諮詢' },
};

const personas = [
  { key: 'fresh-grad',    icon: '🎓', label: '應屆畢業生' },
  { key: 'student',       icon: '📚', label: '在學學生' },
  { key: 'worker',        icon: '👷', label: '勞工/就業' },
  { key: 'middle-aged',  icon: '👨‍💼', label: '中高齡(45+)' },
  { key: 'renter',        icon: '🏠', label: '找租屋' },
  { key: 'homebuyer',     icon: '🏡', label: '想買房' },
  { key: 'entrepreneur',  icon: '💼', label: '想創業' },
  { key: 'parent',        icon: '👶', label: '育兒家庭' },
  { key: 'young-child',  icon: '🍼', label: '育兒(0-6歲)' },
  { key: 'single-parent', icon: '👩‍👧', label: '單親家庭' },
  { key: 'senior',        icon: '👴', label: '長者' },
  { key: 'indigenous',    icon: '🏔️', label: '原住民族' },
  { key: 'disabled',      icon: '♿', label: '身障朋友' },
  { key: 'low-income',    icon: '💰', label: '低/中低收入戶' },
  { key: 'veteran',       icon: '🎖️', label: '榮民' },
  { key: 'farmer',        icon: '🌾', label: '農民' },
];

// Build JSON-LD ItemList for Google rich results (static, build-time, zero runtime cost)
const siteBase = new URL(import.meta.env.BASE_URL, Astro.site ?? 'https://copilot-autogent.github.io').href.replace(/\/?$/, '/');
const jsonLdRaw = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '台灣政府補助清單',
  itemListElement: subsidies.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.title,
    url: `${siteBase}#${s.id}`,
  })),
});
// Escape </script> sequences to prevent breaking out of the script tag
const jsonLd = jsonLdRaw.replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
---

<BaseLayout
  title="補助雷達 — 台灣政府補助一站查詢"
  description="快速查詢台灣政府補助資訊，包含就業、創業、住宅等補助，找到您符合資格的補助方案。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <section class="hero">
    <h1>📡 補助雷達</h1>
    <p>快速找到您符合資格的台灣政府補助，包含就業、創業、住宅及生活補助。</p>
    <div class="hero-youth-hint">🎓 剛畢業？先看「<button id="heroYouthLink" class="hero-youth-link" type="button"><strong>青年必看</strong></button>」，{youthCount} 項補助等你領！</div>
    <div id="pushNotifContainer" class="push-notif-row" style="display:none">
      <button id="subscribeBtn" class="push-btn" type="button">🔔 開啟截止提醒</button>
      <span id="pushStatus" class="push-status"></span>
    </div>
    <div class="calendar-subscribe-row">
      <a href={import.meta.env.BASE_URL.replace(/\/?$/, '/') + 'calendar.ics'} id="calendarSubscribeLink" class="calendar-link" rel="nofollow">
        📅 訂閱截止日曆
      </a>
      <span class="calendar-hint">加入你的日曆 App，不錯過申請期限（自動更新）</span>
      <a href={import.meta.env.BASE_URL.replace(/\/?$/, '/') + 'calendar'} id="calendarViewLink" class="calendar-view-link">
        🗓️ 月曆檢視
      </a>
      <a href={import.meta.env.BASE_URL.replace(/\/?$/, '/') + 'timeline'} id="timelineViewLink" class="timeline-hero-link">
        📅 申請時程表
      </a>
    </div>
  </section>

  <section class="quiz-section" aria-label="快速配對">
    <h2 class="quiz-title">🎯 找出最適合你的補助（5 個問題）</h2>
    
    <div class="quiz-question" data-question="age">
      <label id="quiz-label-age" class="quiz-label">1. 你的年齡是？</label>
      <div class="quiz-options" role="radiogroup" aria-labelledby="quiz-label-age">
        <button class="quiz-option" data-value="youth" type="button" role="radio" aria-checked="false">
          <span class="option-icon">🎓</span>
          <span class="option-text">18-29 歲（青年）</span>
        </button>
        <button class="quiz-option" data-value="adult" type="button" role="radio" aria-checked="false">
          <span class="option-icon">👤</span>
          <span class="option-text">30-64 歲</span>
        </button>
        <button class="quiz-option" data-value="senior" type="button" role="radio" aria-checked="false">
          <span class="option-icon">👴</span>
          <span class="option-text">65 歲以上（長者）</span>
        </button>
      </div>
    </div>

    <div class="quiz-question" data-question="employment" style="display:none">
      <label id="quiz-label-employment" class="quiz-label">2. 你的就業狀況是？</label>
      <div class="quiz-options" role="radiogroup" aria-labelledby="quiz-label-employment">
        <button class="quiz-option" data-value="fresh-grad" type="button" role="radio" aria-checked="false">
          <span class="option-icon">🎓</span>
          <span class="option-text">應屆畢業生／初次求職</span>
        </button>
        <button class="quiz-option" data-value="unemployed" type="button" role="radio" aria-checked="false">
          <span class="option-icon">🔍</span>
          <span class="option-text">待業中</span>
        </button>
        <button class="quiz-option" data-value="employed" type="button" role="radio" aria-checked="false">
          <span class="option-icon">💼</span>
          <span class="option-text">已就業</span>
        </button>
        <button class="quiz-option" data-value="entrepreneur" type="button" role="radio" aria-checked="false">
          <span class="option-icon">💡</span>
          <span class="option-text">想創業</span>
        </button>
      </div>
    </div>

    <div class="quiz-question" data-question="housing" style="display:none">
      <label id="quiz-label-housing" class="quiz-label">3. 你的居住狀況是？</label>
      <div class="quiz-options" role="radiogroup" aria-labelledby="quiz-label-housing">
        <button class="quiz-option" data-value="renter" type="button" role="radio" aria-checked="false">
          <span class="option-icon">🏠</span>
          <span class="option-text">租屋中</span>
        </button>
        <button class="quiz-option" data-value="homebuyer" type="button" role="radio" aria-checked="false">
          <span class="option-icon">🏡</span>
          <span class="option-text">想買房</span>
        </button>
        <button class="quiz-option" data-value="parent" type="button" role="radio" aria-checked="false">
          <span class="option-icon">👶</span>
          <span class="option-text">育兒家庭</span>
        </button>
        <button class="quiz-option" data-value="other" type="button" role="radio" aria-checked="false">
          <span class="option-icon">✓</span>
          <span class="option-text">其他</span>
        </button>
      </div>
    </div>

    <div class="quiz-question" data-question="disability" style="display:none">
      <label id="quiz-label-disability" class="quiz-label">4. 你是否持有身心障礙證明？</label>
      <div class="quiz-options" role="radiogroup" aria-labelledby="quiz-label-disability">
        <button class="quiz-option" data-value="yes" type="button" role="radio" aria-checked="false">
          <span class="option-icon">♿</span>
          <span class="option-text">是（領有身心障礙證明）</span>
        </button>
        <button class="quiz-option" data-value="no" type="button" role="radio" aria-checked="false">
          <span class="option-icon">✓</span>
          <span class="option-text">否</span>
        </button>
      </div>
    </div>

    <div class="quiz-question" data-question="single-parent" style="display:none">
      <label id="quiz-label-single-parent" class="quiz-label">5. 是否為單親家庭？</label>
      <div class="quiz-options" role="radiogroup" aria-labelledby="quiz-label-single-parent">
        <button class="quiz-option" data-value="yes" type="button" role="radio" aria-checked="false">
          <span class="option-icon">👩‍👧</span>
          <span class="option-text">是（離婚、喪偶或未婚生子）</span>
        </button>
        <button class="quiz-option" data-value="no" type="button" role="radio" aria-checked="false">
          <span class="option-icon">✓</span>
          <span class="option-text">否</span>
        </button>
      </div>
    </div>

    <div class="quiz-question" data-question="young-child" style="display:none">
      <label id="quiz-label-young-child" class="quiz-label">6. 家中有 0–6 歲子女？</label>
      <div class="quiz-options" role="radiogroup" aria-labelledby="quiz-label-young-child">
        <button class="quiz-option" data-value="yes" type="button" role="radio" aria-checked="false">
          <span class="option-icon">🍼</span>
          <span class="option-text">是（0–6 歲子女）</span>
        </button>
        <button class="quiz-option" data-value="no" type="button" role="radio" aria-checked="false">
          <span class="option-icon">✓</span>
          <span class="option-text">否</span>
        </button>
      </div>
    </div>

    <div class="quiz-question" data-question="student" style="display:none">
      <label id="quiz-label-student" class="quiz-label">7. 您目前是在學學生（大學／研究所）嗎？</label>
      <div class="quiz-options" role="radiogroup" aria-labelledby="quiz-label-student">
        <button class="quiz-option" data-value="yes" type="button" role="radio" aria-checked="false">
