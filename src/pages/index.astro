          strong.addEventListener('click', handleSuggestion, { once: true });
          strong.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handleSuggestion(); }
          }, { once: true });
          fuzzyHint.append(prefix, strong, suffix);
