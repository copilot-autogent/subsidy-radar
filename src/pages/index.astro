---
import BaseLayout from '../layouts/BaseLayout.astro';
import subsidiesRaw from '../data/subsidies.json';
import HeroSection from '../components/HeroSection.astro';
import QuizSection from '../components/QuizSection.astro';
import QuizResultPanels from '../components/QuizResultPanels.astro';
import PersonaStrip from '../components/PersonaStrip.astro';
import FilterBar from '../components/FilterBar.astro';
import SubsidyCard from '../components/SubsidyCard.astro';
import ComparisonOverlay from '../components/ComparisonOverlay.astro';
import { getFreshnessBadge } from '../utils/freshness.ts';
import {
  safeUrl, normalizeAgency, parseAmountValue,
  deadlineLabel, difficultyLabel, personas,
} from '../utils/helpers.ts';

type Situation = 'renter' | 'homebuyer' | 'entrepreneur' | 'parent' | 'fresh-grad' | 'unemployed' | 'employed' | 'senior' | 'disabled' | 'new-immigrant' | 'indigenous' | 'low-income' | 'single-parent' | 'young-child' | 'student' | 'worker' | 'middle-aged' | 'veteran' | 'farmer';
type Subsidy = typeof subsidiesRaw[number] & {
  isYouthHighlight?: boolean;
  difficulty?: string;
  steps?: string[];
  deadlineDate?: string;
  addedDate?: string;
  situations?: Situation[];
  maxAmount?: number;
  counties?: string[];
  requiredDocs?: string[];
  officialUrl?: string;
  lastVerifiedDate?: string;
  source?: string;
};
const subsidies = subsidiesRaw as Subsidy[];

// ── Related subsidies: build-time pre-computation ─────────────────────────
const DIFFICULTY_ORDER: Record<string, number> = { easy: 0, medium: 1, hard: 2 };

function getRelatedSubsidies(subsidy: Subsidy, all: Subsidy[], max = 3): Subsidy[] {
  const mySituations = new Set<string>(subsidy.situations ?? []);
  if (mySituations.size === 0) return [];
  return all
    .filter(s => s.id !== subsidy.id)
    .map(s => ({ s, shared: (s.situations ?? []).filter(sit => mySituations.has(sit)).length }))
    .filter(({ shared }) => shared > 0)
    .sort(
      (a, b) =>
        b.shared - a.shared ||
        (DIFFICULTY_ORDER[a.s.difficulty ?? 'medium'] ?? 1) -
          (DIFFICULTY_ORDER[b.s.difficulty ?? 'medium'] ?? 1),
    )
    .map(({ s }) => s)
    .slice(0, max);
}

const relatedMap = new Map<string, Subsidy[]>();
subsidies.forEach(s => relatedMap.set(s.id, getRelatedSubsidies(s, subsidies)));

// ── Category counts ────────────────────────────────────────────────────────
const categoryCounts: Record<string, number> = {};
subsidies.forEach(s => {
  categoryCounts[s.category] = (categoryCounts[s.category] || 0) + 1;
});
const youthHighlightCount = subsidies.filter(s => s.isYouthHighlight).length;
const seniorCount = subsidies.filter(
  s => s.situations?.includes('senior') || s.category === '長者',
).length;

const RECENCY_DAYS = 90;
const RECENCY_LABEL = '🆕 最新';
const now = new Date();
now.setHours(0, 0, 0, 0);
const recencyCount = subsidies.filter(s => {
  if (!s.addedDate) return false;
  const [y, m, d] = s.addedDate.split('-').map(Number);
  if (!Number.isFinite(y) || !Number.isFinite(m) || !Number.isFinite(d)) return false;
  if (m < 1 || m > 12 || d < 1 || d > 31) return false;
  const added = new Date(y, m - 1, d);
  if (added.getFullYear() !== y || added.getMonth() !== m - 1 || added.getDate() !== d)
    return false;
  const diff = Math.floor((now.getTime() - added.getTime()) / 86400000);
  return diff >= 0 && diff <= RECENCY_DAYS;
}).length;

const SENIOR_LABEL = '⭐ 長者照護';
const DISABILITY_LABEL = '⭐ 身障';
const disabledCount = subsidies.filter(s => s.situations?.includes('disabled')).length;
const NEW_IMMIGRANT_LABEL = '⭐ 新住民';
const newImmigrantCount = subsidies.filter(s => s.situations?.includes('new-immigrant')).length;
const INDIGENOUS_LABEL = '⭐ 原住民';
const indigenousCount = subsidies.filter(s => s.situations?.includes('indigenous')).length;
const LOW_INCOME_LABEL = '⭐ 低/中低收入戶';
const lowIncomeCount = subsidies.filter(s => s.situations?.includes('low-income')).length;
const SINGLE_PARENT_LABEL = '⭐ 單親';
const singleParentCount = subsidies.filter(s => s.situations?.includes('single-parent')).length;
const YOUNG_CHILD_LABEL = '⭐ 育兒';
const YOUNG_CHILD_CATEGORY = '育兒';
const youngChildCount = subsidies.filter(
  s => s.situations?.includes('young-child') || s.category === YOUNG_CHILD_CATEGORY,
).length;
const STUDENT_LABEL = '⭐ 學生補助';
const studentCount = subsidies.filter(s => s.situations?.includes('student')).length;
const WORKER_LABEL = '⭐ 勞工補助';
const workerCount = subsidies.filter(s => s.situations?.includes('worker')).length;
const MIDDLE_AGED_LABEL = '⭐ 中高齡補助';
const middleAgedCount = subsidies.filter(s => s.situations?.includes('middle-aged')).length;
const VETERAN_LABEL = '⭐ 榮民補助';
const veteranCount = subsidies.filter(s => s.situations?.includes('veteran')).length;
const FARMER_LABEL = '⭐ 農業補助';
const FARMER_CATEGORY = '農業';
const farmerCount = subsidies.filter(s => s.situations?.includes('farmer')).length;

const SENIOR_CATEGORY = '長者';
const categories = [
  '全部',
  '⭐ 青年必看',
  SENIOR_LABEL,
  DISABILITY_LABEL,
  NEW_IMMIGRANT_LABEL,
  INDIGENOUS_LABEL,
  LOW_INCOME_LABEL,
  SINGLE_PARENT_LABEL,
  YOUNG_CHILD_LABEL,
  STUDENT_LABEL,
  WORKER_LABEL,
  MIDDLE_AGED_LABEL,
  VETERAN_LABEL,
  FARMER_LABEL,
  RECENCY_LABEL,
  ...new Set(
    subsidies
      .map(s => s.category)
      .filter(c => c !== SENIOR_CATEGORY && c !== YOUNG_CHILD_CATEGORY && c !== FARMER_CATEGORY),
  ),
];
const youthCount = youthHighlightCount;

// ── Agency filter ─────────────────────────────────────────────────────────
const agencyCounts: Record<string, number> = {};
subsidies.forEach(s => {
  const norm = normalizeAgency(s.agency);
  agencyCounts[norm] = (agencyCounts[norm] || 0) + 1;
});
const AGENCY_DISPLAY_ORDER = [
  '勞動部', '衛福部', '內政部', '教育部', '原民會', '經濟部', '財政部', '農業部', '各縣市', '國科會', '其他',
];
const agencies = AGENCY_DISPLAY_ORDER.filter(a => agencyCounts[a] > 0);

// ── Difficulty counts ─────────────────────────────────────────────────────
const VALID_DIFFICULTIES = new Set(['easy', 'medium', 'hard']);
const difficultyCounts: Record<string, number> = { easy: 0, medium: 0, hard: 0 };
subsidies.forEach(s => {
  const d = (String(s.difficulty ?? 'medium')).trim().toLowerCase() || 'medium';
  if (VALID_DIFFICULTIES.has(d)) difficultyCounts[d]++;
});
const difficultyFilters = [
  { key: 'easy',   label: '🟢 簡單', cls: 'diff-easy-filter' },
  { key: 'medium', label: '🟡 中等', cls: 'diff-medium-filter' },
  { key: 'hard',   label: '🔴 困難', cls: 'diff-hard-filter' },
] as const;

// ── JSON-LD ───────────────────────────────────────────────────────────────
const siteBase = new URL(import.meta.env.BASE_URL, Astro.site ?? 'https://copilot-autogent.github.io')
  .href.replace(/\/?$/, '/');
const jsonLdRaw = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '台灣政府補助清單',
  itemListElement: subsidies.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.title,
    url: `${siteBase}#${s.id}`,
  })),
});
// Escape </script> sequences to prevent breaking out of the script tag
const jsonLd = jsonLdRaw.replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
---

<BaseLayout
  title="補助雷達 — 台灣政府補助一站查詢"
  description="快速查詢台灣政府補助資訊，包含就業、創業、住宅等補助，找到您符合資格的補助方案。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <HeroSection youthCount={youthCount} />

  <QuizSection />

  <QuizResultPanels />

  <PersonaStrip personas={personas} />

  <FilterBar
    categories={categories}
    categoryCounts={categoryCounts}
    totalCount={subsidies.length}
    youthHighlightCount={youthHighlightCount}
    seniorCount={seniorCount}
    disabledCount={disabledCount}
    newImmigrantCount={newImmigrantCount}
    indigenousCount={indigenousCount}
    lowIncomeCount={lowIncomeCount}
    singleParentCount={singleParentCount}
    youngChildCount={youngChildCount}
    studentCount={studentCount}
    workerCount={workerCount}
    middleAgedCount={middleAgedCount}
    veteranCount={veteranCount}
    farmerCount={farmerCount}
    recencyCount={recencyCount}
    recencyDays={RECENCY_DAYS}
    SENIOR_LABEL={SENIOR_LABEL}
    DISABILITY_LABEL={DISABILITY_LABEL}
    NEW_IMMIGRANT_LABEL={NEW_IMMIGRANT_LABEL}
    INDIGENOUS_LABEL={INDIGENOUS_LABEL}
    LOW_INCOME_LABEL={LOW_INCOME_LABEL}
    SINGLE_PARENT_LABEL={SINGLE_PARENT_LABEL}
    YOUNG_CHILD_LABEL={YOUNG_CHILD_LABEL}
    STUDENT_LABEL={STUDENT_LABEL}
    WORKER_LABEL={WORKER_LABEL}
    MIDDLE_AGED_LABEL={MIDDLE_AGED_LABEL}
    VETERAN_LABEL={VETERAN_LABEL}
    FARMER_LABEL={FARMER_LABEL}
    RECENCY_LABEL={RECENCY_LABEL}
    difficultyFilters={difficultyFilters}
    difficultyCounts={difficultyCounts}
    agencies={agencies}
    agencyCounts={agencyCounts}
  />

  <!-- ── Quiz Match Mode Banner ── -->
  <div class="match-mode-banner" id="matchModeBanner" style="display:none" role="status" aria-live="polite" data-testid="match-mode-banner">
    <span class="banner-emoji">🎯</span>
    <span id="matchModeBannerMatch" class="match-mode-banner-text">根據您的回答，找到 <strong><span id="matchModeCount">0</span></strong> 項符合補助，依配對分數排序</span>
    <span id="matchModeBannerNoMatch" class="match-mode-banner-text" style="display:none">目前條件下無符合的補助，可調整篩選條件後重試</span>
    <button class="match-mode-exit-btn" id="matchModeExitBtn" type="button" aria-label="退出配對模式，查看全部補助">查看全部補助 ✕</button>
  </div>

  <!-- Print headers (shown only in @media print) -->
  <div class="print-header" id="printHeader" aria-hidden="true">
    <h1>補助追蹤清單</h1>
    <p>列印於 <span id="printDate"></span></p>
  </div>
  <div class="print-filtered-header" id="printFilteredHeader" aria-hidden="true">
    <h1>補助雷達篩選結果</h1>
    <p>列印於 <span id="printFilteredDate"></span></p>
  </div>

  <div class="grid" id="subsidyGrid" tabindex="-1">
    {subsidies.map(s => (
      <SubsidyCard
        subsidy={s}
        related={relatedMap.get(s.id) ?? []}
        siteBase={siteBase}
      />
    ))}
    <div class="no-results" id="noResults" hidden role="status" aria-live="polite" aria-atomic="true">
      <div class="no-results-emoji">🔍</div>
      <p class="no-results-heading">沒有找到符合的補助</p>
      <p class="no-results-hint">試試：</p>
      <ul class="no-results-tips">
        <li>清除搜尋詞</li>
        <li>換個類別</li>
        <li>使用資格測驗找到適合你的補助</li>
      </ul>
      <div class="no-results-actions">
        <button id="clearFiltersBtn" class="no-results-btn no-results-btn-clear" type="button">清除篩選</button>
        <button id="startQuizBtn" class="no-results-btn no-results-btn-quiz" type="button">→ 測驗</button>
      </div>
    </div>
  </div>

  <div id="share-toast" class="share-toast" role="status" aria-live="polite" aria-atomic="true"></div>

  <!-- Print footer (shown only in @media print body.print-filtered) -->
  <div class="print-filtered-footer" id="printFilteredFooter" aria-hidden="true">
    <span id="printFilteredUrl"></span>
  </div>

  <ComparisonOverlay />

  <script>
    import '../scripts/subsidy-main.ts';
  </script>
</BaseLayout>
