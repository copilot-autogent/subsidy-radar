    border-left-color: #6b7280;
  }

  .pi-deadline {
    font-size: 0.82rem;
    color: #6b7280;
    margin-bottom: 0.25rem;
  }

  .urgency-expired .pi-deadline {
    color: #9ca3af;
    font-style: italic;
  }

  .urgency-urgent .pi-deadline {
    color: #b91c1c;
    font-weight: 600;
  }

  .urgency-soon .pi-deadline {
    color: #b45309;
    font-weight: 500;
  }

  .pi-title {
    font-weight: 600;
    color: #111827;
    font-size: 0.95rem;
  }

  .pi-note {
    font-size: 0.82rem;
    color: #4b5563;
    margin-top: 0.2rem;
  }

  .timeline-by-event {
    max-width: 800px;
    margin: 0 auto 2rem;
    padding: 0 1rem;
