  }

  .detail-link {
    color: #2563eb;
    text-decoration: underline;
  }

  .back-link-row {
    max-width: 800px;
    margin: 0 auto 2rem;
    padding: 0 1rem;
  }

  .back-link {
    color: #2563eb;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .date-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }
    .date-label {
      min-width: unset;
    }
  }
</style>
